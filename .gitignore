# Data files — ignore contents but track directory structure via .gitkeep
data/raw/*
data/processed/*
data/analytics/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/analytics/.gitkeep

# Python
__pycache__/
*.pyc
.env
venv/
*.egg-info/

# dbt
dbt_project/target/
dbt_project/logs/
dbt_project/.user.yml
dbt_project/profiles.yml

# Spark
derby.log
metastore_db/
dist/

# OS
.DS_Store
